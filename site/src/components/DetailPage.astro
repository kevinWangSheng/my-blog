---
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatDate, collectionLabels, type RelatedEntry } from '../lib/content';
import { sitePath } from '../lib/urls';

interface Heading { depth: number; slug: string; text: string; }
interface Props { entry: any; collection: keyof typeof collectionLabels; Content: any; related?: RelatedEntry[]; headings?: Heading[]; }
const { entry, collection, Content, related = [], headings = [] } = Astro.props;
const label = collectionLabels[collection];

const typeNotes: Record<string, string> = {
  projects: 'Project 是能力证据入口:看问题、角色、方案、过程证据和当前进展,不是普通文章列表。',
  notes: 'Note 是短判断 / 知识卡片:保留正在形成但已经可复用的想法。',
  logs: 'Log 是阶段记录 / devlog:只保留对读者有价值的项目或学习过程,不是个人日记或测试内容。',
  essays: 'Essay 是长文综合:把多个观察和判断收束成可对外阅读的表达。',
  links: 'Link 是来源货架:说明为什么某个公开资料值得复访。'
};
const statusLabel: Record<string, string> = { active: 'Active', shipped: 'Shipped', paused: 'Paused', archived: 'Archived' };
const isProject = collection === 'projects';

// 阅读时长:正文以字符估算(中文按 ~450 字/分)。
const charCount = typeof entry.body === 'string' ? entry.body.replace(/\s+/g, '').length : 0;
const minutes = Math.max(1, Math.round(charCount / 450));

// 目录:只取 h2 / h3,>=2 条才显示跟随侧栏。
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
const hasToc = toc.length >= 2;
const tags: string[] = Array.isArray(entry.data.tags) ? entry.data.tags : [];

// 首字下沉(T19 ①):仅 essays,且正文首段以字母 / 中文起头。
// 引号、括号、标点开头则跳过(::first-letter 会带上前导标点,放大后突兀)。
// 检测保守:命中结构块(标题 / 列表 / 引用 / 代码 / 表格)就继续找下一段,
// 找到首个正文段后剥掉行内强调符(* _ ` ~)再看首字。判不准时宁可不下沉。
function essayLeadsWithLetter(body: unknown): boolean {
  if (typeof body !== 'string') return false;
  for (const raw of body.split('\n')) {
    const line = raw.trim();
    if (!line) continue;
    if (/^(#{1,6}\s|>|[-*+]\s|\d+[.)]\s|`{3,}|~{3,}|\||={2,}$|-{3,}$|\*{3,}$|!\[|<)/.test(line)) continue;
    const ch = line.replace(/^[*_`~]+/, '')[0] ?? '';
    return /\p{Letter}/u.test(ch);
  }
  return false;
}
const dropCap = collection === 'essays' && essayLeadsWithLetter(entry.body);
---
<BaseLayout title={`${entry.data.title} · ${label.title}`} description={entry.data.description} type="article">
  <div class:list={["container", hasToc ? "detail-shell" : null]}>
    <article class:list={["prose-article", hasToc ? null : "reading"]}>
      <header class="post-head reveal">
        <p class="kicker">{label.eyebrow}</p>
        <h1>{entry.data.title}</h1>
        <p class="lede">{entry.data.description}</p>
        <div class="post-meta">
          <span class="who"><span class="av" aria-hidden="true"></span><b>Shawn</b></span>
          <time datetime={new Date(entry.data.date).toISOString()}>{formatDate(entry.data.date)}</time>
          {charCount > 0 && (<><span aria-hidden="true">·</span><span>约 {minutes} 分钟</span></>)}
          {tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      </header>

      {isProject && (
        <section class="project-proof" aria-label="Project proof summary">
          <div><span>Role</span><strong>{entry.data.role}</strong></div>
          <div><span>Period</span><strong>{entry.data.period}</strong></div>
          <div><span>Status</span><strong>{statusLabel[entry.data.status] ?? entry.data.status}</strong></div>
          <div><span>Repo / Demo</span><strong>{entry.data.repo || entry.data.demo ? 'Public link available' : '暂未公开 / 本地项目 / 待补充'}</strong></div>
        </section>
      )}

      <div class:list={["prose", dropCap ? "has-drop-cap" : null]}><Content /></div>

      <p class="type-note">{typeNotes[collection]}</p>

      {isProject && (entry.data.repo || entry.data.demo) && (
        <div class="cta-row">
          {entry.data.repo && <a class="button secondary" href={entry.data.repo} target="_blank" rel="noreferrer">Open repo</a>}
          {entry.data.demo && <a class="button secondary" href={entry.data.demo} target="_blank" rel="noreferrer">Open demo</a>}
        </div>
      )}

      {related.length > 0 && (
        <section class="related-section reveal" aria-label="Related entries">
          <h2>继续阅读</h2>
          <div class="related-grid">
            {related.map((item) => (
              <a class="related-card" href={item.path} target={item.external ? '_blank' : undefined} rel={item.external ? 'noreferrer' : undefined}>
                <div class="meta-row">
                  <span>{collectionLabels[item.collection].title}</span>
                  <span>{item.reason}</span>
                </div>
                <strong>{item.title}</strong>
                <p>{item.description}</p>
              </a>
            ))}
          </div>
        </section>
      )}
    </article>

    {hasToc && (
      <aside class="toc" id="toc" aria-label="本页目录">
        <div class="lab">本页目录</div>
        {toc.map((h) => (
          <a href={`#${h.slug}`} class={h.depth === 3 ? 'sub' : undefined}>{h.text}</a>
        ))}
      </aside>
    )}
  </div>

  <script>
    // 文章工艺细节(T19):标题悬停锚点 ④ + 脚注 hover/focus 预览 ③。
    // 二者都是渐进增强:无 JS 时标题仍有 id 可深链、脚注号仍是跳页尾的普通链接。
    // 显隐由 CSS 的 :hover / :focus-within 负责;JS 只负责生成节点与 Esc 关闭。

    // ④ 为正文 h2/h3(Astro 已注入 id)前置一个 # 锚链接。
    function initHeadingAnchors() {
      document.querySelectorAll('.prose h2[id], .prose h3[id]').forEach((h) => {
        const head = h as HTMLElement;
        if (head.dataset.anchored) return;
        head.dataset.anchored = '1';
        const a = document.createElement('a');
        a.className = 'heading-anchor';
        a.href = '#' + head.id;
        a.textContent = '#';
        a.setAttribute('aria-label', '链接到本节:' + (head.textContent || '').trim());
        head.prepend(a);
      });
    }

    // ③ 为 GFM 脚注引用就地生成 popover;CSS 控制显隐,Esc 失焦关闭。
    function initFootnotePopovers() {
      const refs = document.querySelectorAll('.prose a[data-footnote-ref]');
      refs.forEach((node, i) => {
        const ref = node as HTMLAnchorElement;
        if (ref.dataset.fnPop) return;
        const href = ref.getAttribute('href') || '';
        const target = href.startsWith('#')
          ? document.getElementById(decodeURIComponent(href.slice(1)))
          : null;
        if (!target) return;
        // 取脚注正文,剔除「返回正文」回链
        const clone = target.cloneNode(true) as HTMLElement;
        clone.querySelectorAll('a[data-footnote-backref]').forEach((el) => el.remove());
        const text = (clone.textContent || '').replace(/\s+/g, ' ').trim();
        if (!text) return;
        ref.dataset.fnPop = '1';

        const host = (ref.parentElement && ref.parentElement.tagName === 'SUP')
          ? ref.parentElement
          : ref;
        host.classList.add('fn-host');

        const popId = 'fn-pop-' + (i + 1);
        const pop = document.createElement('span');
        pop.className = 'fn-pop';
        pop.id = popId;
        pop.setAttribute('role', 'tooltip');
        pop.textContent = text;
        host.appendChild(pop);

        const described = (ref.getAttribute('aria-describedby') || '').split(/\s+/).filter(Boolean);
        if (!described.includes(popId)) described.push(popId);
        ref.setAttribute('aria-describedby', described.join(' '));

        ref.addEventListener('keydown', (e) => {
          if ((e as KeyboardEvent).key === 'Escape') ref.blur();
        });
      });
    }

    document.addEventListener('astro:page-load', () => {
      initHeadingAnchors();
      initFootnotePopovers();
    });
  </script>
</BaseLayout>
