---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  type?: string;
}
const {
  title = 'Shawn Field Notes',
  description = 'Shawn 的 AI 学习自留地、项目入口和 agent 时代的个人知识手札。',
  type = 'website'
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://kevinwangsheng.github.io');
const nav = [
  ['Projects', '/projects'], ['Notes', '/notes'], ['Logs', '/logs'], ['Essays', '/essays'], ['Links', '/links'], ['About', '/about'], ['RSS', '/rss.xml']
];

import { sitePath } from '../lib/urls';
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={sitePath("/favicon.ico")} />
    <link rel="alternate" type="application/rss+xml" title="Shawn Field Notes RSS" href={sitePath("/rss.xml")} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <nav class="container nav" aria-label="Primary navigation">
          <a class="brand" href={sitePath("/")} aria-label="Shawn Field Notes home">
            <strong>Shawn Field Notes</strong>
            <span>Shawn / learning systems</span>
          </a>
          <div class="nav-links">
            {nav.map(([label, href]) => <a href={sitePath(href)}>{label}</a>)}
          </div>
        </nav>
      </header>
      <main class="site-main">
        <slot />
      </main>
      <footer class="site-footer">
        <div class="container footer-grid">
          <span>© {new Date().getFullYear()} Shawn. Built as a local-first Astro field note.</span>
          <span><a href={sitePath("/rss.xml")}>RSS</a> · no deployment cutover before human acceptance</span>
        </div>
      </footer>
    </div>
    <script is:inline>
      const revealItems = Array.from(document.querySelectorAll('.reveal'));
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce) {
        revealItems.forEach((el) => {
          el.classList.add('is-visible');
          el.dataset.revealState = 'visible';
        });
      } else {
        revealItems.forEach((el, index) => {
          el.dataset.revealState = 'idle';
          el.style.setProperty('--reveal-delay', `${Math.min(index % 6, 5) * 70}ms`);
        });
        const observer = new IntersectionObserver((entries) => {
          for (const entry of entries) {
            const visible = entry.isIntersecting;
            entry.target.classList.toggle('is-visible', visible);
            entry.target.dataset.revealState = visible ? 'visible' : 'idle';
          }
        }, { threshold: 0.18, rootMargin: '-6% 0px -12% 0px' });
        revealItems.forEach((el) => observer.observe(el));
      }
    </script>
  </body>
</html>
