---
import BaseLayout from '../layouts/BaseLayout.astro';
import EntryCard from '../components/EntryCard.astro';
import { getPublicCollection } from '../lib/content';

const [projects, notes, logs, essays, links] = await Promise.all([
  getPublicCollection('projects'), getPublicCollection('notes'), getPublicCollection('logs'), getPublicCollection('essays'), getPublicCollection('links')
]);
const latest = notes.map((entry) => ({ entry, collection: 'notes' as const }))
  .sort((a, b) => +b.entry.data.date - +a.entry.data.date)
  .slice(0, 4);

import { sitePath } from '../lib/urls';
---
<BaseLayout>
  <section class="hero">
    <div class="container hero-grid">
      <div class="reveal">
        <div class="eyebrow">Personal system / public notes</div>
        <h1 class="hero-title">Shawn <span>Field Notes</span></h1>
        <p class="hero-copy">Shawn 的学习自留地:这里先公开 AI 学习、agent workflow、memory 和知识系统判断;项目入口暂时收窄,只保留足够公开且质量过线的内容。</p>
        <div class="cta-row">
          <a class="button" href={sitePath("/essays")}>读 Essays / 长文判断</a>
          <a class="button secondary" href={sitePath("/notes")}>看 Notes / 短观点</a>
        </div>
        <div class="path-grid" aria-label="Primary visitor paths">
          <a class="path-card" href={sitePath("/essays")}><strong>长文判断路径</strong><span>从 agent memory、学习系统和工作流文章理解当前形成的判断。</span></a>
          <a class="path-card" href={sitePath("/notes")}><strong>短观点路径</strong><span>从 note 快速进入 function calling、harness、review gate 等具体判断。</span></a>
        </div>
      </div>
      <aside class="panel instrument reveal" aria-label="Field status panel">
        <div class="meta-row"><span>Current focus</span><span>agent memory / workflow</span></div>
        <div class="orbit"><span>human judgment core</span></div>
        <div class="instrument-grid">
          <div class="metric"><strong>{notes.length}</strong><span>notes</span></div>
          <div class="metric"><strong>{logs.length}</strong><span>logs</span></div>
          <div class="metric"><strong>{essays.length}</strong><span>essays</span></div>
          <div class="metric"><strong>{links.length}</strong><span>sources</span></div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section container">
    <div class="section-head reveal"><div><div class="eyebrow">Learning now</div><h2>What is being calibrated</h2></div><p>短笔记保留“正在生成”的判断,不假装每个想法都已经变成完整文章。</p></div>
    <div class="card-grid">
      {latest.map(({ entry, collection }, index) => <EntryCard entry={entry} collection={collection} size={index === 0 ? 'large' : 'normal'} />)}
    </div>
  </section>

  <section class="section container">
    <div class="section-head reveal"><div><div class="eyebrow">Essays</div><h2>Long-form synthesis</h2></div><p>当一个判断已经稳定到可以对外解释,它会从 note 变成长文。</p></div>
    <div class="card-grid">{essays.slice(0, 2).map((entry) => <EntryCard entry={entry} collection="essays" size="medium" />)}</div>
  </section>

  <section class="section container">
    <div class="section-head reveal"><div><div class="eyebrow">Links</div><h2>Source shelf</h2></div><p>保留值得复访的来源,并写清楚它为什么进入这个系统。</p></div>
    <div class="list-stack">
      {links.slice(0, 4).map((entry) => <a class="panel link-card reveal" href={entry.data.url}><div class="meta-row"><span>{entry.data.category}</span><span>{entry.data.date.toISOString().slice(0,10)}</span></div><h3>{entry.data.title}</h3><p>{entry.data.note}</p></a>)}
    </div>
  </section>
</BaseLayout>
