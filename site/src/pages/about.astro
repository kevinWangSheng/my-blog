---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

import { sitePath } from '../lib/urls';
---
<BaseLayout title="About · Shawn Field Notes" description="About 页面暂时留空,等待公开信息确认后再补。">
  <PageHero eyebrow="About" title="About" description="这里先暂时留空。等公开介绍、联系入口和个人表述确认后再补。" />
  <section class="reading prose reveal">
    <p>About 页面目前不写未确认的个人介绍。先保留一个最小入口,避免把不准确的信息发布出去。</p>
    <div class="cta-row">
      <a class="button" href={sitePath("/essays")}>阅读长文</a>
      <a class="button secondary" href={sitePath("/notes")}>短观点</a>
      <a class="button secondary" href={sitePath("/rss.xml")}>订阅 RSS</a>
    </div>
  </section>
</BaseLayout>
