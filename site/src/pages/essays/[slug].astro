---
import { getCollection, render } from 'astro:content';
import DetailPage from '../../components/DetailPage.astro';
import { entrySlug, getRelatedEntries } from '../../lib/content';

export async function getStaticPaths() {
  const entries = await getCollection('essays', ({ data }) => data.visibility === 'public');
  return Promise.all(entries.map(async (entry) => ({ params: { slug: entrySlug(entry) }, props: { entry, related: await getRelatedEntries('essays', entry) } })));
}
const { entry, related } = Astro.props;
const { Content } = await render(entry);
---
<DetailPage collection="essays" entry={entry} Content={Content} related={related} />
